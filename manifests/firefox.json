{
    "manifest_version": 2,
    "name": "Kuviyam Notes",
    "version": "1.0.0",
    "description": "Kuviyam Notes — A lightweight, privacy-first note-taking extension with sticky note UI.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "contextMenus",
        "tabs",
        "<all_urls>"
    ],
    "browser_action": {
        "default_popup": "index.html",
        "default_title": "Kuviyam Notes",
        "default_icon": {
            "16": "logo.png",
            "32": "logo.png",
            "48": "logo.png",
            "128": "logo.png"
        }
    },
    "icons": {
        "16": "logo.png",
        "32": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
    },
    "web_accessible_resources": [
        "logo.png",
        "sticky-notes-icon.svg"
    ],
    "background": {
        "scripts": ["src/background/index.ts"],
        "persistent": false
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content/index.tsx"
            ]
        }
    ],
    "commands": {
        "toggle-panel": {
            "suggested_key": {
                "default": "Alt+Shift+P"
            },
            "description": "Toggle Kuviyam Floating Panel"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "kuviyam-notes@extension",
            "strict_min_version": "109.0"
        }
    }
}
