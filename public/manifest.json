{
    "manifest_version": 3,
    "name": "Kuviyam",
    "version": "1.0.3",
    "description": "A lightweight, privacy-first browser-based note-taking extension.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "contextMenus",
        "sidePanel",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "index.html",
        "default_title": "Kuviyam"
    },
    "background": {
        "service_worker": "src/background.ts",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content.tsx"
            ]
        }
    ],
    "commands": {
        "toggle-panel": {
            "suggested_key": {
                "default": "Alt+Shift+P",
                "mac": "Alt+Shift+P",
                "windows": "Alt+Shift+P"
            },
            "description": "Toggle Kuviyam Floating Panel"
        }
    }
}